{% import "macros.html" as macros %}
{% set posts_section = get_section(path="posts/_index.md") %}
{% set_global listed_pages = [] %}
{% for page in posts_section.pages %}
  {% if page.extra.listed | default(value=true) %}
    {% set_global listed_pages = listed_pages | concat(with=page) %}
  {% endif %}
{% endfor %}
{% set latest = listed_pages | first %}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://www.getzola.org/">Zola</generator>
  <link href="{{ get_url(path='feed.xml', trailing_slash=false) | safe }}" rel="self" type="application/atom+xml" />
  <link href="{{ config.base_url | safe }}/" rel="alternate" type="text/html" />
  <updated>{% if latest %}{{ latest.date | date(format="%+") }}{% else %}{{ now() | date(format="%+") }}{% endif %}</updated>
  <id>{{ get_url(path='feed.xml', trailing_slash=false) | safe }}</id>
  <title type="html">{{ config.title }}</title>
  <subtitle>{{ config.description }}</subtitle>
  <author>
    <name>{{ config.author }}</name>
  </author>
  {% for page in listed_pages %}
    <entry>
      <title type="html">{{ page.title }}</title>
      <link href="{{ macros::legacy_url(url=page.permalink) | safe }}" rel="alternate" type="text/html" title="{{ page.title }}" />
      <published>{{ page.date | date(format="%+") }}</published>
      <updated>{{ page.updated | default(value=page.date) | date(format="%+") }}</updated>
      <id>{{ page.permalink | replace(from=".html", to="") | safe }}</id>
      <content type="html" xml:base="{{ macros::legacy_url(url=page.permalink) | safe }}"><![CDATA[{{ page.content }}]]></content>
      {% if page.extra.authors %}
      <author><name>{{ page.extra.authors | join(sep=", ") }}</name></author>
      {% endif %}
      {% if page.description %}
      <summary type="html">{{ page.description }}</summary>
      {% endif %}
    </entry>
  {% endfor %}
</feed>
